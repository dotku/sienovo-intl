# Postiz self-host config — copy to .env and fill in.
# Used by docker-compose.yml. Do NOT commit .env.

# Public URL Caddy will serve (must match the Caddyfile site address)
POSTIZ_URL=https://postiz.sienovo.cn

# Generate with:  openssl rand -hex 48
JWT_SECRET=

# Generate with:  openssl rand -hex 24
POSTGRES_PASSWORD=

# Keep registration off so randos can't sign up. Flip to false ONLY while
# creating the first admin user, then flip back to true and restart.
DISABLE_REGISTRATION=true

# Optional — enables Postiz's "AI suggest" inside the composer.
OPENAI_API_KEY=

# Social OAuth — leave blank initially. Fill in from each platform's
# developer console after Postiz is up and you decide which channels to wire.
# Postiz reads these at boot, so re-run `docker compose up -d` after editing.
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
